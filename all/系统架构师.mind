{"root":{"data":{"id":"dhaujhp9c0w0","created":1774338603746,"text":"系统架构师"},"children":[{"data":{"id":"dhaujsax6rc0","created":1774338626823,"text":"软件工程"},"children":[{"data":{"id":"dhaukbywr1k0","created":1774338669633,"text":"开放模型","expandState":"collapse"},"children":[{"data":{"id":"dhaukw45fi00","created":1774338713485,"text":"瀑布模型"},"children":[{"data":{"id":"dhaum6g2hvk0","created":1774338814338,"text":"被称为软件周期型，一个阶段到另一个阶段下降像瀑布"},"children":[]},{"data":{"id":"dhaun0v5sds0","created":1774338880554,"text":"前一阶段的成果是后一阶段的输入"},"children":[]}]},{"data":{"id":"dhaunfoqw0o0","created":1774338912819,"text":"螺旋模型"},"children":[{"data":{"id":"dhaunnw5vcw0","created":1774338930680,"text":"在快速原型的基础上扩展而成"},"children":[]},{"data":{"id":"dhauo6fsmnc0","created":1774338971050,"text":"有多个阶段，每个阶段4部分组成","expandState":"collapse"},"children":[{"data":{"id":"dhaupwfi7u80","created":1774339105993,"text":"目标设定","priority":1},"children":[]},{"data":{"id":"dhaupypx4c00","created":1774339110976,"text":"风险分析","priority":2},"children":[]},{"data":{"id":"dhauq8vrg540","created":1774339133097,"text":"开发和有效性验证","priority":3},"children":[]},{"data":{"id":"dhauqezjiew0","created":1774339146386,"text":"评审","priority":4},"children":[]}]}]},{"data":{"id":"dhaur3axg7c0","created":1774339199318,"text":"构建组装模型"},"children":[{"data":{"id":"dhaurq1bim80","created":1774339248803,"text":"通过重用来提高软件的可靠性和易维护性"},"children":[]}]}]},{"data":{"id":"dhautythak80","created":1774339424648,"text":"UML","expandState":"collapse"},"children":[{"data":{"id":"dhauugq77pc0","created":1774339463632,"text":"14种图","expandState":"collapse"},"children":[{"data":{"id":"dhauujyv0kg0","created":1774339470686,"text":"结构图"},"children":[{"data":{"id":"dhauv8lu5xk0","created":1774339524318,"text":"类、对象、构建、部署、制品、包图、组合结构图"},"children":[]}]},{"data":{"id":"dhauv0lpvls0","created":1774339506896,"text":"行为图"},"children":[{"data":{"id":"dhauw36qfa80","created":1774339590885,"text":"用例图、顺序图、通信图、定时图、交互概览图，活动图，状态图"},"children":[]}]}]}]},{"data":{"id":"dhauww0hgcw0","created":1774339653634,"text":"面向对象设计"},"children":[{"data":{"id":"dhaux0ihk680","created":1774339663429,"text":"原则"},"children":[{"data":{"id":"dhaux1utcc80","created":1774339666351,"text":"单一职责原则"},"children":[]},{"data":{"id":"dhauygmvlsw0","created":1774339776887,"text":"依赖倒置原则"},"children":[]},{"data":{"id":"dhauz6j2dyo0","created":1774339833253,"text":"组合重用原则"},"children":[{"data":{"id":"dhauzg1hxpc0","created":1774339853959,"text":"要尽量的使用组合，而非继承"},"children":[]}]},{"data":{"id":"dhauzpc99wg0","created":1774339874200,"text":"迪米特原则"},"children":[{"data":{"id":"dhauzwmnwjc0","created":1774339890067,"text":"一个对象应尽量对其他对象有尽可能少的了解"},"children":[]}]}]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}